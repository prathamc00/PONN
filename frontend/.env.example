# ─────────────────────────────────────────────────────────────────────────────
# Frontend — Environment Variables Template
# Copy to .env.local for local dev or .env.production for production builds.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL (used by apiFetch and socket connection)
# In development, Vite proxies /api → http://localhost:5000, so leave as '/api'
VITE_API_URL=/api

# Backend base URL — used for direct file/upload links only
# In development, leave empty so relative paths work via vite proxy.
# In production with separate domains, set to: https://api.yourdomain.com
VITE_BACKEND_URL=
